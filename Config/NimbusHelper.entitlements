<?xml version="1.0" encoding="UTF-8"?>
<!--
  Privileged helper entitlements. The helper runs as root via SMAppService.
  It must NOT be sandboxed. Sign with the same Developer ID + Hardened Runtime as
  the app; the listener verifies the client's team id before accepting connections.
-->
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>com.apple.security.app-sandbox</key>
    <false/>
</dict>
</plist>
