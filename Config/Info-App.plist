<?xml version="1.0" encoding="UTF-8"?>
<!-- Key Info.plist entries for the Nimbus app target. Merge into the target's
     generated Info.plist (or set as INFOPLIST_KEY_* build settings). -->
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleIdentifier</key>
    <string>com.nimbus.app</string>
    <key>CFBundleName</key>
    <string>Nimbus</string>
    <key>CFBundleShortVersionString</key>
    <string>1.0.2</string>
    <key>CFBundleVersion</key>
    <string>3</string>
    <key>LSMinimumSystemVersion</key>
    <string>14.0</string>

    <!-- App is a regular windowed app that also vends a menu-bar item; not agent-only. -->
    <key>LSUIElement</key>
    <false/>

    <!-- Shown when the app first touches protected locations; FDA is granted by the
         user in System Settings → Privacy & Security → Full Disk Access. -->
    <key>NSDesktopFolderUsageDescription</key>
    <string>Nimbus scans your Desktop to find large files and duplicates.</string>
    <key>NSDocumentsFolderUsageDescription</key>
    <string>Nimbus scans your Documents to find large files and duplicates.</string>
    <key>NSDownloadsFolderUsageDescription</key>
    <string>Nimbus scans your Downloads to find large files and duplicates.</string>
</dict>
</plist>
